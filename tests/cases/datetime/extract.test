# timestamps: examples using the precision_timestamp and precision_timestamp_tz types
extract('YEAR'::str, '2016-12-31T13:30:15'::pts<6>) = 2016::i64
extract('ISOYEAR'::str, '2016-01-01T13:30:15'::pts<6>) = 2015::i64
extract('QUARTER'::str, '2016-12-31T13:30:15'::pts<6>) = 4::i64
extract('MONTH'::str, '2016-12-31T13:30:15'::pts<6>) = 12::i64
extract('WEEK'::str, '2016-12-31T13:30:15'::pts<6>) = 52::i64
extract('DAY'::str, '2016-12-31T13:30:15'::pts<6>) = 31::i64
extract('ISODOW'::str, '2016-12-25T13:30:15'::pts<6>) = 7::i64
extract('DOW'::str, '2016-12-25T13:30:15'::pts<6>) = 0::i64
extract('DOY'::str, '2016-12-25T13:30:15'::pts<6>) = 360::i64
extract('HOUR'::str, '2016-12-31T13:30:15'::pts<6>) = 13::i64
extract('MINUTE'::str, '2016-12-31T13:30:15'::pts<6>) = 30::i64
extract('SECOND'::str, '2016-12-31T13:30:15'::pts<6>) = 15::i64
extract('MILLISECONDS'::str, '2016-12-31T13:30:15'::pts<6>) = 15000::i64
extract('MICROSECONDS'::str, '2016-12-31T13:30:15.220000'::pts<6>) = 15220000::i64
extract('EPOCH'::str, '2016-12-31T13:30:15'::pts<6>) = 1483191015::i64

# date: examples using the date type
extract('YEAR'::str, '2020-12-31'::date) = 2020::i64
extract('MONTH'::str, '2020-12-31'::date) = 12::i64
extract('DAY'::str, '2020-12-31'::date) = 31::i64

# time: examples using the precision_time type
