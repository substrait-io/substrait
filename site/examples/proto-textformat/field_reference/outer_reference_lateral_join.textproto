# Outer reference in a lateral join (correlated subquery via LateralJoinRel)
#
# Scenario: For each customer, retrieve their matching orders. The right
# side of the lateral join is evaluated once per left row, referencing
# the left row's customer_id to correlate the two relations.
#
# SQL equivalent:
#   SELECT c.*, o.*
#   FROM customers c
#   LEFT JOIN LATERAL (
#     SELECT *
#     FROM orders
#     WHERE orders.customer_id = c.customer_id   -- outer reference
#   ) o ON true
#
# Plan structure:
#
#   LateralJoinRel [rel_anchor=5, type=LEFT]
#     ├── expression: { literal: { boolean: true } }
#     ├── left:  ReadRel(customers)          -- output: (customer_id, name, ...)
#     └── right: FilterRel
#                  condition: orders.customer_id = outer_ref(rel_reference=5, field 0)
#                  └── ReadRel(orders)
#
# The LateralJoinRel has RelCommon.rel_anchor = 5. The right
# input's filter uses an OuterReference with rel_reference = 5 to access
# the left input's schema. Field 0 of the left input is customer_id.
#
# message Expression.FieldReference

outer_reference: {
  rel_reference: 5  # Refers to the LateralJoinRel whose RelCommon.rel_anchor = 5
}
direct_reference: {
  struct_field: {
    field: 0        # First column of the left input (customers.customer_id)
  }
}
